{
    "name": "adsbao",
    "version": "0.4.0",
    "description": "ADSBao airport explorer app",
    "author": "orriduck",
    "repository": {
        "type": "git",
        "url": "https://github.com/orriduck/ADSBao.git"
    },
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder"
    },
    "devDependencies": {
        "electron": "^33.0.0",
        "electron-builder": "^25.1.8"
    },
    "dependencies": {
        "get-port": "^5.1.1"
    },
    "build": {
        "appId": "com.adsbao.app",
        "productName": "ADSBao",
        "mac": {
            "category": "public.app-category.utilities",
            "target": [
                "dmg",
                "zip",
                "pkg"
            ],
            "hardenedRuntime": true,
            "gatekeeperAssess": false
        },
        "directories": {
            "output": "dist"
        },
        "extraResources": [
            {
                "from": "../../backend/dist/backend_app",
                "to": "backend_dist",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "files": [
            "main.js",
            "package.json",
            "node_modules/**/*"
        ]
    }
}
