{
    "runway_rules": {
        "description": "Rules for pronouncing runway identifiers.",
        "patterns": [
            {
                "regex": "RUNWAY \\d{1,2}[LRC]?",
                "instruction": "State the word 'RUNWAY' followed by digits. Even if the pilot says 'Tree', output '3'.",
                "examples": [
                    "RUNWAY 27",
                    "RUNWAY 33L",
                    "RUNWAY 9R"
                ]
            }
        ]
    },
    "tail_number_rules": {
        "description": "Rules for pronouncing aircraft tail numbers (N-numbers).",
        "patterns": [
            {
                "format": "N[1-9][0-9]{0,4}[A-Z]{0,2}",
                "instruction": "All U.S. registration begins with 'NOVEMBER' (spoken) or 'N' (written). Use digits for the identification number. Even if spoken as 'TREE', output '3'.",
                "examples": [
                    "NOVEMBER 123AZ",
                    "NOVEMBER 549C"
                ]
            },
            {
                "short_form": "Last 3 characters used after initial contact. Use digits.",
                "examples": [
                    "4AZ",
                    "9C"
                ]
            }
        ]
    },
    "waypoint_rules": {
        "description": "Rules for pronouncing waypoints or reporting points (sometimes called tracepoints).",
        "synonyms": [
            "TRACEPOINT",
            "REPORTING POINT",
            "FIX",
            "INTERSECTION"
        ],
        "patterns": [
            {
                "type": "5-letter waypoints",
                "instruction": "Usually 5-letter names pronounced as words. If it sounds like a common word (e.g., 'STEP'), check if it matches a known waypoint (e.g., 'SZEP').",
                "examples": [
                    "KAIHO",
                    "BOSTON",
                    "GOLDA",
                    "SZEP"
                ]
            },
            {
                "reporting": "Phraseology: [ID] OVER [WAYPOINT] [ALTITUDE]. Use digits for altitude.",
                "examples": [
                    "NOVEMBER 123 OVER KAIHO AT 4500"
                ]
            }
        ]
    },
    "frequency_reporting": {
        "description": "How frequencies are communicated.",
        "patterns": [
            {
                "type": "Decimal frequencies",
                "instruction": "Mentioned as 'POINT' followed by digits. Use digits in output.",
                "examples": [
                    "121.9",
                    "POINT 9",
                    "118.3"
                ]
            }
        ]
    },
